# Foundation substrate values — fill in after §1 of README.md.
# Copy this file to `.substrate.env` (gitignored) and edit.

# ─── IdP target ──────────────────────────────────────────────────────────
# WSO2 IS 7.2.0 default
WSO2_IS_BASE_URL=https://13.60.190.47:9443
WSO2_IS_TOKEN_URL=https://13.60.190.47:9443/oauth2/token
WSO2_IS_AUTHZ_URL=https://13.60.190.47:9443/oauth2/authorize
WSO2_IS_AUTHN_URL=https://13.60.190.47:9443/oauth2/authn
WSO2_IS_JWKS_URL=https://13.60.190.47:9443/oauth2/jwks
WSO2_IS_INTROSPECT_URL=https://13.60.190.47:9443/oauth2/introspect

# Self-signed dev cert: tests use `-k`. Set 0 once a real cert is in place.
INSECURE_TLS=1

# ─── Probe substrate (from README §1) ────────────────────────────────────
# probe-client-a — primary confidential app, used as actor in C2 + middle
# actor in C3.
PROBE_CLIENT_A_ID=
PROBE_CLIENT_A_SECRET=

# probe-client-b — second confidential app, used as outer actor in C3.
PROBE_CLIENT_B_ID=
PROBE_CLIENT_B_SECRET=

# probe-user — local user in the IS for C2's password-grant subject token.
PROBE_USER_USERNAME=probe.user
PROBE_USER_PASSWORD=

# Probe API audience (matches API Resource registered in §1.3)
PROBE_API_AUDIENCE=urn:probe:api
PROBE_API_SECONDARY_AUDIENCE=urn:probe:other
PROBE_API_SCOPES=probe.read probe.write
