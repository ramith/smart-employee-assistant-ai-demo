# IT MCP Server configuration (it_server)
# Authoritative var list: it_server/config.py
# IdP: on-prem WSO2 Identity Server, e.g. https://13.60.190.47:9443
# No secret values here — fill in from the IS Console / your deployment.

# ─── IdP baseline ─────────────────────────────────────────────────────────
# Required. WSO2 IS root URL (no trailing slash, no path).
WSO2_IS_BASE_URL=https://<is-host>:9443
# Optional. Default both to <WSO2_IS_BASE_URL>/oauth2/token and /oauth2/jwks.
AUTH_ISSUER=https://<is-host>:9443/oauth2/token
JWKS_URL=https://<is-host>:9443/oauth2/jwks
# Optional. Token introspection endpoint (used when introspection is enabled).
WSO2_IS_INTROSPECT_URL=https://<is-host>:9443/oauth2/introspect

# Optional. "true" disables TLS verification — dev only (self-signed IS cert).
DISABLE_SSL_VERIFY=false

# ─── Token-B audience + trust (F-04) ──────────────────────────────────────
# Required. The IT agent's OAuth Client ID — every inbound token-B must carry
# this value as `aud`. Logged at INFO on startup.
IT_SERVER_EXPECTED_AUD=<it-agent-oauth-client-id-from-IS-Console>
# Optional. Comma-separated Agent ID UUIDs allowed as `act.sub` in token-B
# (the nested-act allowlist; usually the it-agent's Agent ID UUID).
IT_SERVER_TRUSTED_PEER_AGENTS=<it-agent-agent-id-uuid>
# Optional. Default scope required on every tool call.
IT_SERVER_REQUIRED_SCOPES=it_assets_read_rest

# ─── Introspection ─────────────────────────────────────────────────────────
# Optional. Default true.
IT_SERVER_INTROSPECT_ENABLED=true

# ─── Revocation fan-out (must match the rest of the fleet) ─────────────────
# Optional. Shared secret authenticating /internal/events fan-out. Empty
# disables the receiver. Set the SAME value across all five services.
INTERNAL_REVOKE_SHARED_SECRET=

# ─── CORS / bind ───────────────────────────────────────────────────────────
# Optional. Must include the origin the SPA is served from (orchestrator).
ALLOWED_ORIGINS=http://localhost:8090,http://127.0.0.1:8090
# Optional. Bind defaults are 0.0.0.0:8004 (compose binds host loopback only).
IT_SERVER_HOST=0.0.0.0
IT_SERVER_PORT=8004

# ─── Observability (optional) ──────────────────────────────────────────────
# Read by the `amp-instrument` launch wrapper (not by it_server/config.py).
# OpenTelemetry export to WSO2 Agent Manager. Leave blank to skip export.
AMP_OTEL_ENDPOINT=
AMP_AGENT_API_KEY=
