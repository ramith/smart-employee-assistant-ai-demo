# Asgardeo Configuration (SPA client)
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your-tenant>
CLIENT_ID=<spa-client-id-from-asgardeo>

# Port the client dev server listens on. Change this if 3001 is taken;
# remember to also update REDIRECT_URI below, ALLOWED_ORIGINS in agent/.env
# and hr-server/.env, and register the new redirect URL in the Asgardeo SPA app.
CLIENT_PORT=3001

# Must match a URL registered in the Asgardeo SPA app's "Authorized redirect URLs".
REDIRECT_URI=http://localhost:3001/callback

# Backend URLs
AGENT_SERVER_URL=http://localhost:5001
HR_SERVER_URL=http://localhost:8000
