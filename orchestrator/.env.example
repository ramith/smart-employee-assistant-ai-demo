# Orchestrator configuration (orchestrator)
# Authoritative var list: orchestrator/config.py
# IdP: on-prem WSO2 Identity Server, e.g. https://13.60.190.47:9443
# LLM: OpenAI (gpt-4.1) via the WSO2 Agent Manager (embedded WSO2 AI Gateway).
# No secret values here — fill in from the IS Console / gateway / deployment.

# ─── IdP baseline ─────────────────────────────────────────────────────────
# Required. WSO2 IS root URL (no trailing slash, no path).
WSO2_IS_BASE_URL=https://<is-host>:9443
# Optional. Default both to <WSO2_IS_BASE_URL>/oauth2/token and /oauth2/jwks.
WSO2_IS_ISSUER=https://<is-host>:9443/oauth2/token
WSO2_IS_JWKS_URL=https://<is-host>:9443/oauth2/jwks
# Optional. "1"/"true" disables TLS verification — dev only (self-signed cert).
IDP_INSECURE_TLS=0

# ─── orchestrator-mcp-client (confidential MCP Client Application) ─────────
# The ONLY OAuth client used at runtime — drives both the /authorize redirect
# and the /token code exchange (IS requires the same client_id on both).
# Required.
ORCHESTRATOR_MCP_CLIENT_ID=<mcp-client-id-from-IS-Console>
ORCHESTRATOR_MCP_CLIENT_SECRET=<mcp-client-secret-from-IS-Console>
# Optional. Must be a registered Callback URL on orchestrator-mcp-client.
# Default: http://localhost:8090/agent-callback
ORCHESTRATOR_MCP_CLIENT_REDIRECT_URI=http://localhost:8090/agent-callback

# ─── orchestrator-agent (4-value Agent identity, App-Native Auth) ──────────
# Required. Agent ID is the `sub`; the auto-created OAuth App backs it on
# /oauth2/* endpoints. Agent Secret is distinct from the OAuth Client Secret.
ORCHESTRATOR_AGENT_ID=<orchestrator-agent-id-uuid>
ORCHESTRATOR_AGENT_SECRET=<orchestrator-agent-secret>
ORCHESTRATOR_AGENT_OAUTH_CLIENT_ID=<orchestrator-agent-oauth-client-id>
ORCHESTRATOR_AGENT_OAUTH_CLIENT_SECRET=<orchestrator-agent-oauth-client-secret>

# ─── Specialist endpoints (in-cluster compose DNS) ─────────────────────────
# Required.
HR_AGENT_URL=http://hr_agent:8001
IT_AGENT_URL=http://it_agent:8002
# Optional. MCP backends for the revocation fan-out (defaults shown).
HR_SERVER_URL=http://hr_server:8000
IT_SERVER_URL=http://it_server:8004

# ─── F-15 collision check (orchestrator asserts these three are distinct) ──
# Required. The two specialist agents' OAuth Client IDs (the orchestrator's own
# is ORCHESTRATOR_AGENT_OAUTH_CLIENT_ID above).
HR_AGENT_OAUTH_CLIENT_ID=<hr-agent-oauth-client-id>
IT_AGENT_OAUTH_CLIENT_ID=<it-agent-oauth-client-id>

# ─── Inbound A2A trust ─────────────────────────────────────────────────────
# Optional. Comma-separated specialist Agent ID UUIDs allowed as `act.sub` on
# inbound A2A callbacks (hr-agent + it-agent Agent IDs).
TRUSTED_SPECIALIST_SUBS=<hr-agent-agent-id-uuid>,<it-agent-agent-id-uuid>

# ─── Logout ────────────────────────────────────────────────────────────────
# Optional. Sent on RP-initiated logout; must be a registered Callback URL on
# orchestrator-mcp-client. Default: http://localhost:8090/
POST_LOGOUT_REDIRECT_URI=http://localhost:8090/

# ─── LLM routing — OpenAI via the WSO2 Agent Manager (AI Gateway) ──────────
# Optional. "llm" routes/composes via OpenAI with the keyword router as the
# automatic fallback; "keyword" (default) skips the LLM entirely.
LLM_FALLBACK_MODE=llm
# OpenAI-compatible gateway base URL (the WSO2 AI Gateway endpoint).
OPENAI_BASE_URL=https://<ai-gateway-host>/<route>
# Header carrying the key (gateway default is "api-key").
OPENAI_API_HEADER=api-key
OPENAI_API_KEY=<openai-or-gateway-api-key>
# Default code value is gpt-4o; the demo uses gpt-4.1.
OPENAI_MODEL=gpt-4.1
# Optional tuning (defaults shown).
LLM_TIMEOUT_S=8
LLM_MAX_OUTPUT_TOKENS=256
LLM_COMPOSER_MAX_OUTPUT_TOKENS=1024
PUBLIC_CHAT_LLM_TIMEOUT_S=5

# ─── Revocation fan-out (must match the rest of the fleet) ─────────────────
# Optional. Shared secret authenticating /internal/events fan-out. Empty
# disables fan-out. Set the SAME value across all five services.
INTERNAL_REVOKE_SHARED_SECRET=

# ─── CORS / bind / session / cookie ────────────────────────────────────────
# Optional. Must include the origin the SPA is loaded from.
ALLOWED_ORIGINS=http://localhost:8090,http://127.0.0.1:8090
# Optional. Container listens on 8080; compose maps host 8090 -> 8080.
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8080
# Optional (defaults shown).
SESSION_COOKIE_NAME=orch_sid
SESSION_TTL_SECONDS=28800
# Optional. Set "true" only when served over HTTPS.
COOKIE_SECURE=false

# ─── Observability (optional) ──────────────────────────────────────────────
# Read by the `amp-instrument` launch wrapper (not by orchestrator/config.py).
# OpenTelemetry export to WSO2 Agent Manager. Leave blank to skip export.
AMP_OTEL_ENDPOINT=
AMP_AGENT_API_KEY=
