# IT specialist agent configuration (it_agent)
# Authoritative var list: it_agent/config.py
# IdP: on-prem WSO2 Identity Server, e.g. https://13.60.190.47:9443
# No secret values here — fill in from the IS Console / your deployment.
#
# NOTE: docker-compose.yml already injects IT_MCP_SERVER_URL,
# IT_EXPECTED_INBOUND_AUD, IT_AGENT_HOST and INTERNAL_REVOKE_SHARED_SECRET
# into the container environment. They are listed here for completeness /
# running the service outside compose.

# ─── IdP baseline ─────────────────────────────────────────────────────────
# Required. WSO2 IS root URL (no trailing slash, no path).
WSO2_IS_BASE_URL=https://<is-host>:9443
# Optional. Default both to <WSO2_IS_BASE_URL>/oauth2/token and /oauth2/jwks.
WSO2_IS_ISSUER=https://<is-host>:9443/oauth2/token
WSO2_IS_JWKS_URL=https://<is-host>:9443/oauth2/jwks
# Optional. "1"/"true" disables TLS verification — dev only (self-signed cert).
IDP_INSECURE_TLS=0

# ─── it-agent identity (4-value Agent identity, App-Native Auth) ───────────
# Required. Agent ID is the `sub`; the OAuth App backs it on /oauth2/*.
# The Agent Secret is distinct from the OAuth Client Secret.
IT_AGENT_ID=<it-agent-id-uuid>
IT_AGENT_SECRET=<it-agent-secret>
IT_AGENT_OAUTH_CLIENT_ID=<it-agent-oauth-client-id>
IT_AGENT_OAUTH_CLIENT_SECRET=<it-agent-oauth-client-secret>
# Optional. Default: http://localhost:9999/agent-callback
IT_AGENT_REDIRECT_URI=http://localhost:9999/agent-callback

# ─── MCP backend + inbound trust ───────────────────────────────────────────
# Required. IT MCP server base URL (compose injects http://it_server:8004).
IT_MCP_SERVER_URL=http://it_server:8004
# Required. Audience expected on inbound token-A — the orchestrator
# MCP client_id (compose injects ORCHESTRATOR_MCP_CLIENT_ID).
IT_EXPECTED_INBOUND_AUD=<orchestrator-mcp-client-id>
# Optional. Comma-separated orchestrator Agent ID UUIDs allowed as `act.sub`
# on inbound A2A calls.
IT_TRUSTED_PEER_AGENTS=<orchestrator-agent-id-uuid>

# ─── CIBA ──────────────────────────────────────────────────────────────────
# Optional (defaults shown).
IT_CIBA_SCOPE=openid it_assets_read_rest
IT_MAX_POLL_SECONDS=240

# ─── Revocation fan-out (must match the rest of the fleet) ─────────────────
# Optional. Shared secret authenticating /internal/events fan-out. Empty
# disables the receiver. Set the SAME value across all five services.
INTERNAL_REVOKE_SHARED_SECRET=

# ─── Bind / canonical URL ──────────────────────────────────────────────────
# Optional (defaults shown). Compose binds host port 8002 to loopback only.
IT_AGENT_HOST=0.0.0.0
IT_AGENT_PORT=8002
IT_AGENT_CANONICAL_URL=http://it_agent:8002/a2a

# ─── Observability (optional) ──────────────────────────────────────────────
# Read by the `amp-instrument` launch wrapper (not by it_agent/config.py).
# OpenTelemetry export to WSO2 Agent Manager. Leave blank to skip export.
AMP_OTEL_ENDPOINT=
AMP_AGENT_API_KEY=
